---

<section id="channels" class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-2xl sm:text-3xl font-bold mb-4">{t.channels.title}</h2>
    <p class="text-gray-600 mb-12 max-w-xl mx-auto">{t.channels.subtitle}</p>
    <div class="flex flex-wrap justify-center gap-6">
      {channels.map((ch) => (
        <div class="flex flex-col items-center gap-3 bg-white rounded-2xl p-6 shadow-sm border border-gray-100 w-36">
          <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${ch.color} flex items-center justify-center shadow-sm`} set:html={ch.icon} />
          <span class="font-semibold text-gray-800">{ch.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
