---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 max-w-6xl mx-auto">
  <div class="text-center max-w-3xl mx-auto">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-violet-50 border border-violet-200 rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse"></span>
      <span class="text-sm font-medium text-violet-700">{t.hero.badge}</span>
    </div>

    <!-- Title -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
      {t.hero.title.split('\n').map((line, i) => (
        <span>
          {i === 1 ? <span class="bg-gradient-to-r from-violet-600 to-indigo-600 bg-clip-text text-transparent">{line}</span> : line}
          {i === 0 && <br />}
        </span>
      ))}
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-gray-600 mb-10 whitespace-pre-line">
      {t.hero.subtitle}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`/${lang}/#pricing`} class="w-full sm:w-auto bg-gradient-to-r from-violet-600 to-indigo-600 text-white font-semibold px-8 py-3.5 rounded-xl hover:opacity-90 transition shadow-lg shadow-violet-500/25">
        {t.hero.cta}
      </a>
      <a href={`/${lang}/#how`} class="w-full sm:w-auto text-gray-700 font-medium px-8 py-3.5 rounded-xl border border-gray-200 hover:border-gray-300 hover:bg-gray-50 transition">
        {t.hero.secondary}
      </a>
    </div>

    <!-- Hero visual: Homework help flow -->
    <div class="mt-16 relative">
      <div class="absolute inset-0 bg-gradient-to-t from-white via-transparent to-transparent z-10 pointer-events-none"></div>
      <div class="bg-gradient-to-br from-violet-50 to-indigo-50 rounded-2xl p-6 sm:p-10 border border-violet-100 max-w-3xl mx-auto">
        <!-- Step indicator -->
        <div class="flex items-center justify-center gap-2 mb-6">
          <span class="text-xs font-semibold text-violet-500 uppercase tracking-wider">{t.hero.flowLabel}</span>
          <span class="flex gap-1">
            <span class="w-6 h-1.5 rounded-full bg-violet-500"></span>
            <span class="w-6 h-1.5 rounded-full bg-violet-300"></span>
            <span class="w-6 h-1.5 rounded-full bg-violet-300"></span>
          </span>
        </div>

        <div class="flex flex-col gap-5">
          <!-- Step 1: Kid sends photo -->
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0 text-sm">🧒</div>
            <div class="flex-1">
              <p class="text-xs text-gray-400 mb-1 font-medium">{lang === 'vi' ? 'Minh' : 'Minh'}</p>
              <!-- Photo placeholder -->
              <div class="bg-white rounded-xl rounded-tl-sm p-3 shadow-sm border border-gray-100">
                <div class="bg-gray-50 rounded-lg p-3 mb-2 flex items-center gap-3">
                  <div class="w-14 h-14 rounded-lg bg-amber-50 border border-amber-200 flex items-center justify-center flex-shrink-0">
                    <svg class="w-7 h-7 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-medium text-gray-600">{t.hero.photoLabel}</p>
                    <p class="text-[10px] text-gray-400 mt-0.5">IMG_0426.jpg</p>
                  </div>
                </div>
                <p class="text-sm text-gray-700">{t.hero.kidMessage}</p>
              </div>
            </div>
          </div>

          <!-- Step 2: Sibl analyzes + guides -->
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center flex-shrink-0 text-sm">✨</div>
            <div class="flex-1">
              <p class="text-xs text-violet-400 mb-1 font-medium">Sibl</p>
              <div class="bg-gradient-to-br from-violet-500 to-indigo-600 rounded-xl rounded-tl-sm p-4 text-white shadow-sm">
                <p class="text-violet-100 text-sm leading-relaxed">
                  {t.hero.siblReply}
                </p>
              </div>
            </div>
          </div>

          <!-- Step 3: Parent report -->
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-xs text-green-500 mb-1 font-medium">{t.hero.reportLabel}</p>
              <div class="bg-white rounded-xl p-3 shadow-sm border border-green-100">
                <p class="text-xs text-gray-600 leading-relaxed">{t.hero.parentReport}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
