---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<article class="pt-32 pb-20 px-4 sm:px-6 lg:px-8 max-w-3xl mx-auto">
  <h1 class="text-3xl sm:text-4xl font-bold mb-2">{t.terms.title}</h1>
  <p class="text-sm text-gray-500 mb-10">{t.terms.lastUpdated}</p>

  <p class="text-gray-700 mb-10 leading-relaxed">{t.terms.intro}</p>

  <!-- Section 1 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section1.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section1.p1}</p>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section1.p2}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section1.p3}</p>
  </section>

  <!-- Section 2 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section2.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section2.p1}</p>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section2.p2}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section2.p3}</p>
  </section>

  <!-- Section 3 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section3.title}</h2>
    <ul class="list-disc list-inside space-y-2 text-gray-700">
      {t.terms.section3.items.map((item: string) => (
        <li class="leading-relaxed">{item}</li>
      ))}
    </ul>
  </section>

  <!-- Section 4 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section4.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section4.p1}</p>
    <ul class="list-disc list-inside space-y-2 text-gray-700 mb-2">
      {t.terms.section4.items.map((item: string) => (
        <li class="leading-relaxed">{item}</li>
      ))}
    </ul>
    <p class="text-gray-700 leading-relaxed">{t.terms.section4.p2}</p>
  </section>

  <!-- Section 5 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section5.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section5.p1}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section5.p2}</p>
  </section>

  <!-- Section 6 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section6.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section6.p1}</p>
    <ul class="list-disc list-inside space-y-2 text-gray-700 mb-2">
      {t.terms.section6.items.map((item: string) => (
        <li class="leading-relaxed">{item}</li>
      ))}
    </ul>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section6.p2}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section6.p3}</p>
  </section>

  <!-- Section 7 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section7.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section7.p1}</p>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section7.p2}</p>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section7.p3}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section7.p4}</p>
  </section>

  <!-- Section 8 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section8.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section8.p1}</p>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section8.p2}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section8.p3}</p>
  </section>

  <!-- Section 9 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section9.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section9.p1}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section9.p2}</p>
  </section>

  <!-- Section 10 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section10.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section10.p1}</p>
    <p class="text-gray-700 leading-relaxed">{t.terms.section10.p2}</p>
  </section>

  <!-- Section 11 -->
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-3">{t.terms.section11.title}</h2>
    <p class="text-gray-700 leading-relaxed mb-2">{t.terms.section11.p1}</p>
    <a href={`mailto:${t.terms.section11.email}`} class="text-violet-600 hover:text-violet-700 font-medium">{t.terms.section11.email}</a>
  </section>
</article>
